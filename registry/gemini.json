          "/v1beta/models"
        ]
      }
    },
    {
      "id": "gemini/tuned-models",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1beta/tunedModels"
        ]
      }
    }
  ]
}
