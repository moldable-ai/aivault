{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "gemini",
  "vaultSecrets": {
    "GEMINI_API_KEY": "secret"
  },
  "auth": {
    "query": {
      "param_name": "key"
    }
  },
  "hosts": [
    "generativelanguage.googleapis.com"
  ],
  "capabilities": [
    {
      "id": "gemini/batches",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1beta/batches"
        ]
      }
    },
    {
      "id": "gemini/cached-content",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1beta/cachedContents"
        ]
      }
    },
    {
      "id": "gemini/corpora",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1beta/corpora"
        ]
      }
    },
    {
      "id": "gemini/file-search",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/upload/v1beta/fileSearchStores",
          "/v1beta/fileSearchStores"
        ]
      }
    },
    {
      "id": "gemini/files",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/upload/v1beta/files",
          "/v1beta/files"
        ]
      }
    },
    {
      "id": "gemini/generated-files",
      "provider": "gemini",
      "allow": {
        "hosts": [
          "generativelanguage.googleapis.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1beta/generatedFiles"
        ]
      }
    },
    {
      "id": "gemini/models",
      "provider": "gemini",
      "allow": {
