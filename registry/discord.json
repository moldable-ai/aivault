{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "discord",
  "vaultSecrets": {
    "DISCORD_BOT_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bot {{secret}}"
    }
  },
  "hosts": [
    "discord.com"
  ],
  "capabilities": [
    {
      "id": "discord/applications",
      "provider": "discord",
      "allow": {
        "hosts": [
          "discord.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/api/v10/applications"
        ]
      }
    },
    {
      "id": "discord/channels",
      "provider": "discord",
      "allow": {
        "hosts": [
          "discord.com"
        ],
