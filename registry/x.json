{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "x",
  "vaultSecrets": {
    "X_BEARER_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.x.com"
  ],
  "capabilities": [
    {
      "id": "x/dm",
      "provider": "x",
      "allow": {
        "hosts": [
          "api.x.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/2/dm_conversations",
          "/2/dm_events"
        ]
      }
    },
    {
      "id": "x/lists",
      "provider": "x",
      "allow": {
        "hosts": [
          "api.x.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/2/lists"
        ]
      }
    },
    {
      "id": "x/spaces",
      "provider": "x",
      "allow": {
        "hosts": [
          "api.x.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/2/spaces"
        ]
      }
    },
    {
      "id": "x/tweets",
      "provider": "x",
      "allow": {
        "hosts": [
          "api.x.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/2/tweets"
        ]
      }
    },
    {
      "id": "x/users",
      "provider": "x",
      "allow": {
        "hosts": [
          "api.x.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/2/users"
        ]
      }
    }
  ]
}
