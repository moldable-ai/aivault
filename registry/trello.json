{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "trello",
  "vaultSecrets": {
    "TRELLO_API_KEY": "key",
    "TRELLO_TOKEN": "token"
  },
  "auth": {
    "multi_query": [
      {
        "param_name": "key",
        "value_template": "{{key}}"
      },
      {
        "param_name": "token",
        "value_template": "{{token}}"
      }
    ]
  },
  "hosts": [
    "api.trello.com"
  ],
  "capabilities": [
    {
      "id": "trello/actions",
      "provider": "trello",
      "allow": {
        "hosts": [
          "api.trello.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PUT"
        ],
        "pathPrefixes": [
          "/1/actions"
        ]
      }
    },
    {
      "id": "trello/batch",
      "provider": "trello",
      "allow": {
        "hosts": [
          "api.trello.com"
        ],
