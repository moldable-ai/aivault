{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "remove-bg",
  "vaultSecrets": {
    "REMOVE_BG_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "X-Api-Key",
      "value_template": "{{secret}}"
    }
  },
  "hosts": [
    "api.remove.bg"
  ],
  "capabilities": [
    {
      "id": "remove-bg/background-removal",
      "provider": "remove-bg",
      "allow": {
        "hosts": [
          "api.remove.bg"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/v1.0/removebg"
        ]
      }
    }
  ]
}
