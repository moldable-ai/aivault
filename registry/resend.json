{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "resend",
  "vaultSecrets": {
    "RESEND_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.resend.com"
  ],
  "capabilities": [
    {
      "id": "resend/broadcasts",
      "provider": "resend",
      "allow": {
        "hosts": [
          "api.resend.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/broadcasts"
        ]
      }
    },
    {
      "id": "resend/contacts",
      "provider": "resend",
      "allow": {
        "hosts": [
          "api.resend.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/contacts"
        ]
      }
    },
    {
      "id": "resend/domains",
      "provider": "resend",
      "allow": {
        "hosts": [
          "api.resend.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/domains"
        ]
      }
    },
    {
      "id": "resend/emails",
      "provider": "resend",
      "allow": {
        "hosts": [
          "api.resend.com"
        ],
        "methods": [
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/emails"
        ]
      }
    }
  ]
}
