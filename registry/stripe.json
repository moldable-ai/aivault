{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "stripe",
  "vaultSecrets": {
    "STRIPE_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.stripe.com"
  ],
  "capabilities": [
    {
      "id": "stripe/billing",
      "provider": "stripe",
      "allow": {
        "hosts": [
          "api.stripe.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/invoices",
          "/v1/prices",
          "/v1/products",
          "/v1/subscriptions"
        ]
      }
    },
    {
      "id": "stripe/customers",
      "provider": "stripe",
      "allow": {
        "hosts": [
          "api.stripe.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/customers"
        ]
      }
    },
    {
      "id": "stripe/disputes",
      "provider": "stripe",
      "allow": {
        "hosts": [
          "api.stripe.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/disputes",
          "/v1/payouts"
        ]
      }
    },
    {
      "id": "stripe/payments",
      "provider": "stripe",
      "allow": {
        "hosts": [
          "api.stripe.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/balance_transactions",
          "/v1/charges",
          "/v1/payment_intents",
          "/v1/refunds"
        ]
      }
    }
  ]
}
