{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "youtube",
  "vaultSecrets": {
    "YOUTUBE_API_KEY": "secret"
  },
  "auth": {
    "query": {
      "param_name": "key"
    }
  },
  "hosts": [
    "www.googleapis.com"
  ],
  "capabilities": [
    {
      "id": "youtube/captions",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/youtube/v3/captions"
        ]
      }
    },
    {
      "id": "youtube/channels",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "GET",
          "PUT"
        ],
        "pathPrefixes": [
          "/youtube/v3/channelBanners",
          "/youtube/v3/channelSections",
          "/youtube/v3/channels"
        ]
      }
    },
    {
      "id": "youtube/comments",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/youtube/v3/commentThreads",
          "/youtube/v3/comments"
        ]
      }
    },
    {
      "id": "youtube/playlists",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/youtube/v3/playlistItems",
          "/youtube/v3/playlists"
        ]
      }
    },
    {
      "id": "youtube/search",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/youtube/v3/search"
        ]
      }
    },
    {
      "id": "youtube/subscriptions",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/youtube/v3/subscriptions"
        ]
      }
    },
    {
      "id": "youtube/videos",
      "provider": "youtube",
      "allow": {
        "hosts": [
          "www.googleapis.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/youtube/v3/videos"
        ]
      }
    }
  ]
}
