{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "mailgun",
  "vaultSecrets": {
    "MAILGUN_API_KEY": "password"
  },
  "auth": "basic",
  "hosts": [
    "api.mailgun.net"
  ],
  "capabilities": [
    {
      "id": "mailgun/domains",
      "provider": "mailgun",
      "allow": {
        "hosts": [
          "api.mailgun.net"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v3/domains"
        ]
      }
    },
    {
      "id": "mailgun/lists",
      "provider": "mailgun",
      "allow": {
        "hosts": [
          "api.mailgun.net"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v3/lists"
        ]
      }
    },
    {
      "id": "mailgun/routes",
      "provider": "mailgun",
      "allow": {
        "hosts": [
          "api.mailgun.net"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v3/routes"
        ]
      }
    },
    {
      "id": "mailgun/sending",
      "provider": "mailgun",
      "allow": {
        "hosts": [
          "api.mailgun.net"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v3/"
        ]
      }
    }
  ]
}
