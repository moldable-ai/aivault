{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "github",
  "vaultSecrets": {
    "GITHUB_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.github.com"
  ],
  "capabilities": [
    {
      "id": "github/gists",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/gists"
        ]
      }
    },
    {
      "id": "github/graphql",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/graphql"
        ]
      }
    },
    {
      "id": "github/issues",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/issues"
        ]
      }
    },
    {
      "id": "github/meta",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/emojis",
          "/gitignore",
          "/licenses",
          "/meta",
          "/rate_limit"
        ]
      }
    },
    {
      "id": "github/notifications",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "PUT"
        ],
        "pathPrefixes": [
          "/notifications"
        ]
      }
    },
    {
      "id": "github/orgs",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/organizations",
          "/orgs"
        ]
      }
    },
    {
      "id": "github/repos",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/repos"
        ]
      }
    },
    {
      "id": "github/search",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/search"
        ]
      }
    },
    {
      "id": "github/users",
      "provider": "github",
      "allow": {
        "hosts": [
          "api.github.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/user",
          "/users"
        ]
      }
    }
  ]
}
