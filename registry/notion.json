{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "notion",
  "vaultSecrets": {
    "NOTION_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.notion.com"
  ],
  "capabilities": [
    {
      "id": "notion/blocks",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/blocks"
        ]
      }
    },
    {
      "id": "notion/comments",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/comments"
        ]
      }
    },
    {
      "id": "notion/databases",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/databases"
        ]
      }
    },
    {
      "id": "notion/pages",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/pages"
        ]
      }
    },
    {
      "id": "notion/search",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/v1/search"
        ]
      }
    },
    {
      "id": "notion/users",
      "provider": "notion",
      "allow": {
        "hosts": [
          "api.notion.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/users"
        ]
      }
    }
  ]
}
