{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "sendgrid",
  "vaultSecrets": {
    "SENDGRID_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.sendgrid.com"
  ],
  "capabilities": [
    {
      "id": "sendgrid/mail",
      "provider": "sendgrid",
      "allow": {
        "hosts": [
          "api.sendgrid.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/v3/mail"
        ]
      }
    },
    {
      "id": "sendgrid/marketing",
      "provider": "sendgrid",
      "allow": {
        "hosts": [
          "api.sendgrid.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v3/marketing"
        ]
      }
    },
    {
      "id": "sendgrid/stats",
      "provider": "sendgrid",
      "allow": {
        "hosts": [
          "api.sendgrid.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v3/categories",
          "/v3/stats"
        ]
      }
    },
    {
      "id": "sendgrid/suppressions",
      "provider": "sendgrid",
      "allow": {
        "hosts": [
          "api.sendgrid.com"
        ],
        "methods": [
          "DELETE",
          "GET"
        ],
        "pathPrefixes": [
          "/v3/suppression"
        ]
      }
    },
    {
      "id": "sendgrid/templates",
      "provider": "sendgrid",
      "allow": {
        "hosts": [
          "api.sendgrid.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v3/templates"
        ]
      }
    }
  ]
}
