{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "openai",
  "vaultSecrets": {
    "OPENAI_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.openai.com"
  ],
  "credentialAlternatives": [
    {
      "id": "codex-oauth",
      "vaultSecrets": {
        "CODEX_OAUTH_JSON": "oauth"
      },
      "auth": {
        "multi_header": [
          {
            "header_name": "authorization",
            "value_template": "Bearer {{access_token}}"
          },
          {
            "header_name": "ChatGPT-Account-Id",
            "value_template": "{{account_id}}"
          }
        ]
      },
      "hosts": [
        "chatgpt.com"
      ],
      "capabilities": [
        "openai/codex-responses"
      ],
      "priority": 100,
      "upstreamPathPrefix": "/backend-api/codex"
    }
  ],
  "capabilities": [
    {
      "id": "openai/assistants",
      "provider": "openai",
      "allow": {
        "hosts": [
          "api.openai.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/assistants",
          "/v1/threads"
        ]
      }
    },
    {
      "id": "openai/batch",
      "provider": "openai",
      "allow": {
        "hosts": [
          "api.openai.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/batches"
        ]
      }
    },
    {
      "id": "openai/chat-completions",
      "provider": "openai",
      "allow": {
        "hosts": [
          "api.openai.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/chat/completions"
        ]
      }
    },
    {
      "id": "openai/codex-responses",
      "provider": "openai",
      "allow": {
        "hosts": [
          "chatgpt.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/responses"
        ]
      }
    },
    {
      "id": "openai/embeddings",
      "provider": "openai",
      "allow": {
        "hosts": [
