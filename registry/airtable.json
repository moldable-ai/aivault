{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "airtable",
  "vaultSecrets": {
    "AIRTABLE_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.airtable.com"
  ],
  "capabilities": [
    {
      "id": "airtable/meta",
      "provider": "airtable",
      "allow": {
        "hosts": [
          "api.airtable.com"
        ],
        "methods": [
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v0/meta/bases"
        ]
      }
    },
    {
      "id": "airtable/records",
      "provider": "airtable",
      "allow": {
        "hosts": [
          "api.airtable.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v0/"
        ]
      }
    },
    {
      "id": "airtable/webhooks",
      "provider": "airtable",
      "allow": {
        "hosts": [
          "api.airtable.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v0/bases"
        ]
      }
    }
  ]
}
