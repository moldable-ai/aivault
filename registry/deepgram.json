{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "deepgram",
  "vaultSecrets": {
    "DEEPGRAM_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Token {{secret}}"
    }
  },
  "hosts": [
    "agent.deepgram.com",
    "api.deepgram.com"
  ],
  "capabilities": [
    {
      "id": "deepgram/models",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "api.deepgram.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/models"
        ]
      }
    },
    {
      "id": "deepgram/projects",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "api.deepgram.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/projects"
        ]
      }
    },
    {
      "id": "deepgram/text-intelligence",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "api.deepgram.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/v1/read"
        ]
      }
    },
    {
      "id": "deepgram/text-to-speech",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "api.deepgram.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/speak"
        ]
      }
    },
    {
      "id": "deepgram/transcription",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "api.deepgram.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/listen"
        ]
      }
    },
    {
      "id": "deepgram/voice-agent",
      "provider": "deepgram",
      "allow": {
        "hosts": [
          "agent.deepgram.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/agent"
        ]
      }
    }
  ]
}
