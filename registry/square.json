{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "square",
  "vaultSecrets": {
    "SQUARE_ACCESS_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "connect.squareup.com"
  ],
  "capabilities": [
    {
      "id": "square/catalog",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v2/catalog"
        ]
      }
    },
    {
      "id": "square/customers",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v2/customers"
        ]
      }
    },
    {
      "id": "square/inventory",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v2/inventory"
        ]
      }
    },
    {
      "id": "square/invoices",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST",
          "PUT"
        ],
        "pathPrefixes": [
          "/v2/invoices"
        ]
      }
    },
    {
      "id": "square/locations",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v2/locations"
        ]
      }
    },
    {
      "id": "square/orders",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v2/orders"
        ]
      }
    },
    {
      "id": "square/payments",
      "provider": "square",
      "allow": {
        "hosts": [
          "connect.squareup.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v2/payments"
        ]
      }
    }
  ]
}
