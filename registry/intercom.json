{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "intercom",
  "vaultSecrets": {
    "INTERCOM_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.intercom.io"
  ],
  "capabilities": [
    {
      "id": "intercom/admins",
      "provider": "intercom",
      "allow": {
        "hosts": [
          "api.intercom.io"
        ],
        "methods": [
          "GET",
          "PUT"
        ],
        "pathPrefixes": [
          "/admins",
          "/me"
        ]
      }
    },
    {
      "id": "intercom/articles",
      "provider": "intercom",
      "allow": {
        "hosts": [
          "api.intercom.io"
        ],
        "methods": [
