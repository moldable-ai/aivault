{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "replicate",
  "vaultSecrets": {
    "REPLICATE_API_TOKEN": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "Bearer {{secret}}"
    }
  },
  "hosts": [
    "api.replicate.com"
  ],
  "capabilities": [
    {
      "id": "replicate/collections",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "GET"
        ],
        "pathPrefixes": [
          "/v1/collections"
        ]
      }
    },
    {
      "id": "replicate/deployments",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/deployments"
        ]
      }
    },
    {
      "id": "replicate/files",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/files"
        ]
      }
    },
    {
      "id": "replicate/models",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "DELETE",
          "GET",
          "PATCH",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/models"
        ]
      }
    },
    {
      "id": "replicate/predictions",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/predictions"
        ]
      }
    },
    {
      "id": "replicate/trainings",
      "provider": "replicate",
      "allow": {
        "hosts": [
          "api.replicate.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/v1/trainings"
        ]
      }
    }
  ]
}
