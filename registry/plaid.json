{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "plaid",
  "vaultSecrets": {
    "PLAID_CLIENT_ID": "client_id",
    "PLAID_SECRET": "secret"
  },
  "auth": {
    "multi_header": [
      {
        "header_name": "PLAID-CLIENT-ID",
        "value_template": "{{client_id}}"
      },
      {
        "header_name": "PLAID-SECRET",
        "value_template": "{{secret}}"
      }
    ]
  },
  "hosts": [
    "production.plaid.com"
  ],
  "capabilities": [
    {
      "id": "plaid/accounts",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/accounts"
        ]
      }
    },
    {
      "id": "plaid/assets",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
          "GET",
          "POST"
        ],
        "pathPrefixes": [
          "/asset_report"
        ]
      }
    },
    {
      "id": "plaid/auth",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/auth"
        ]
      }
    },
    {
      "id": "plaid/categories",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
