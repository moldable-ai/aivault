        ]
      }
    },
    {
      "id": "plaid/identity",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/identity"
        ]
      }
    },
    {
      "id": "plaid/institutions",
      "provider": "plaid",
      "allow": {
        "hosts": [
          "production.plaid.com"
        ],
        "methods": [
          "POST"
        ],
        "pathPrefixes": [
          "/institutions"
        ]
      }
    },
    {
      "id": "plaid/investments",
