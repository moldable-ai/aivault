{
  "$schema": "./schemas/registry-provider.schema.json",
  "provider": "deepl",
  "vaultSecrets": {
    "DEEPL_API_KEY": "secret"
  },
  "auth": {
    "header": {
      "header_name": "authorization",
      "value_template": "DeepL-Auth-Key {{secret}}"
    }
  },
  "hosts": ["api-free.deepl.com"],
  "capabilities": [
    {
      "id": "deepl/translate",
      "provider": "deepl",
      "allow": {
        "hosts": ["api-free.deepl.com"],
        "methods": ["POST"],
        "pathPrefixes": ["/v2/translate"]
      }
    },
    {
      "id": "deepl/languages",
      "provider": "deepl",
      "allow": {
        "hosts": ["api-free.deepl.com"],
        "methods": ["GET"],
        "pathPrefixes": ["/v2/languages"]
      }
    },
    {
      "id": "deepl/usage",
      "provider": "deepl",
      "allow": {
        "hosts": ["api-free.deepl.com"],
        "methods": ["GET"],
        "pathPrefixes": ["/v2/usage"]
      }
    }
  ]
}
